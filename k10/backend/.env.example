# Server Configuration
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30
SERVER_WRITE_TIMEOUT=30

# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=digitaltwin
DB_SSLMODE=disable

# TimescaleDB Configuration
TS_HOST=localhost
TS_PORT=5432
TS_USER=postgres
TS_PASSWORD=postgres
TS_NAME=timeseries
TS_SSLMODE=disable

# MQTT Configuration
MQTT_BROKER=tcp://localhost:1883
MQTT_CLIENT_ID=digitaltwin-server
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1

# Anomaly Detection Configuration
ANOMALY_CONTAMINATION=0.05
ANOMALY_N_TREES=100
ANOMALY_SAMPLE_SIZE=256
ANOMALY_MAX_SAMPLES=256
ANOMALY_TRAIN_INTERVAL=3600
ANOMALY_DETECT_INTERVAL=5
