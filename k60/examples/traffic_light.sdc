# Auto-generated by fsm2v compiler (Intel FPGA SDC format)
# FSM: traffic_light | Clock: 100 MHz | Target: IntelCyclone10

# Clock constraint
create_clock -name clk -period 10 [get_ports {clk}]

# Async reset constraint
set_false_path -from [get_ports {rst_n}]

# Input delays
set_input_delay -clock clk 3 [get_ports {sensor}]
set_input_delay -clock clk 3 [get_ports {emergency}]

# Output delays
set_output_delay -clock clk 3 [get_ports {light}]

