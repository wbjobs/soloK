# Auto-generated by fsm2v compiler
# FSM: traffic_light | Clock: 100 MHz | Target: Xilinx7Series

# Clock constraint
create_clock -name clk -period 10 [get_ports clk]

# Async reset constraint
set_false_path -from [get_ports rst_n]

# Input delays
set_input_delay -clock clk -max 4 [get_ports sensor]
set_input_delay -clock clk -min 1.2 [get_ports sensor]
set_input_delay -clock clk -max 4 [get_ports emergency]
set_input_delay -clock clk -min 1.2 [get_ports emergency]

# Output delays
set_output_delay -clock clk -max 4 [get_ports light]
set_output_delay -clock clk -min 1.2 [get_ports light]

# Clock uncertainty
set_clock_uncertainty -setup 0.5 [get_clocks clk]
set_clock_uncertainty -hold 0.25 [get_clocks clk]

# FSM state encoding attributes
set_property FSM_ENCODING AUTO [get_cells -hierarchical -filter {NAME =~ */current_state*}]
set_property SAFE_IMPLEMENTATION SAFE [get_cells -hierarchical -filter {NAME =~ */current_state*}]
